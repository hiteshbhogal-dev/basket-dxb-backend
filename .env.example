# Basket DXB — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── API Keys (optional — improves scrape reliability) ──────────────────
# Carrefour API key (obtain from their developer portal if available)
CARREFOUR_API_KEY=

# Spinneys Algolia key (public search-only key — update if it rotates)
SPINNEYS_ALGOLIA_APP_ID=RQQ0HHKBBD
SPINNEYS_ALGOLIA_API_KEY=d0d298aa7c24a02c39c1a7d69d682bb2

# ── Database ────────────────────────────────────────────────────────────
# Path to SQLite DB file (relative to project root)
DB_PATH=db/basket_dxb.db

# ── API Server ──────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Scraper Settings ────────────────────────────────────────────────────
# Seconds between requests per store (random between MIN and MAX)
SCRAPER_DELAY_MIN=1.5
SCRAPER_DELAY_MAX=4.0

# Max concurrent HTTP requests (keep low to avoid bans)
SCRAPER_CONCURRENCY=4

# Retry failed requests N times before giving up
SCRAPER_RETRIES=2

# ── Scheduler ───────────────────────────────────────────────────────────
# Cron time in Asia/Dubai timezone (default: 06:00 every morning)
SCRAPE_HOUR=6
SCRAPE_MINUTE=0

# ── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/basket_dxb.log
